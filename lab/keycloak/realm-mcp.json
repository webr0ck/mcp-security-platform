{
  "realm": "mcp",
  "enabled": true,
  "displayName": "MCP Security Platform",
  "loginWithEmailAllowed": true,
  "sslRequired": "none",
  "attributes": {
    "frontendUrl": "${LAB_HOST_URL:http://localhost:8082}"
  },
  "accessTokenLifespan": 900,
  "refreshTokenMaxReuse": 0,
  "ssoSessionMaxLifespan": 86400,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "waitIncrementSeconds": 300,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "passwordPolicy": "",
  "clients": [
    {
      "id": "00000001-0000-0000-0000-000000000001",
      "clientId": "mcp-proxy",
      "name": "MCP Security Proxy",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KC_PROXY_CLIENT_SECRET}",
      "redirectUris": [
        "http://localhost:8000/api/v1/auth/oidc/callback",
        "http://localhost:8088/api/v1/auth/oidc/callback",
        "http://${LAB_HOST}:8000/api/v1/auth/oidc/callback",
        "http://${LAB_HOST}:8088/api/v1/auth/oidc/callback",
        "https://localhost:8443/api/v1/auth/oidc/callback",
        "https://${LAB_HOST}:8443/api/v1/auth/oidc/callback"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://localhost:8088",
        "http://${LAB_HOST}:8000",
        "http://${LAB_HOST}:8088",
        "https://localhost:8443",
        "https://${LAB_HOST}:8443"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "frontchannelLogout": true,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "use.refresh.tokens": "true",
        "token.response.include.issued.token.type": "true"
      },
      "protocolMappers": [
        {
          "name": "roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "client-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "config": {
            "claim.name": "resource_access.${clientId}.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "usermodel.clientRoleMapping.clientId": "mcp-proxy"
          }
        },
        {
          "name": "audience-mcp-proxy",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "mcp-proxy",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "claude-code",
      "name": "Claude Code MCP Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "redirectUris": [
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "webOrigins": [
        "+"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "86400"
      },
      "defaultClientScopes": [
        "openid",
        "basic",
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "offline_access"
      ],
      "protocolMappers": [
        {
          "name": "mcp-proxy-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "mcp-proxy",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "grafana",
      "name": "Grafana",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KC_GRAFANA_CLIENT_SECRET}",
      "redirectUris": [
        "http://localhost:3000/login/generic_oauth",
        "http://${LAB_HOST}:3000/login/generic_oauth"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "admin-cli",
      "name": "Admin CLI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "bearerOnly": false
    },
    {
      "clientId": "lab-test",
      "name": "Lab Test Client (ROPC \u2014 lab only, never production)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KC_LAB_TEST_SECRET:lab-test-secret}",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "defaultClientScopes": [
        "openid",
        "basic",
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "offline_access"
      ],
      "protocolMappers": [
        {
          "name": "audience-mcp-proxy",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "mcp-proxy",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "svc-mcp-agent",
      "name": "MCP Service Account (shared robot credential)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KC_SVC_MCP_AGENT_SECRET:svc-mcp-agent-secret}",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "defaultClientScopes": [
        "openid",
        "basic",
        "profile",
        "email",
        "roles"
      ],
      "protocolMappers": [
        {
          "name": "audience-mcp-proxy",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "mcp-proxy",
            "access.token.claim": "true"
          }
        },
        {
          "name": "client-roles-mcp-proxy",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "config": {
            "claim.name": "resource_access.${clientId}.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "usermodel.clientRoleMapping.clientId": "mcp-proxy"
          }
        }
      ]
    },
    {
      "id": "00000002-0000-0000-0000-000000000001",
      "clientId": "lab-tickets",
      "name": "Lab Tickets Service",
      "description": "Case-4 token-exchange target resource server (PRD-0002)",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "lab-tickets-secret",
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "redirectUris": [
        "http://localhost:9000/*"
      ],
      "webOrigins": [],
      "protocol": "openid-connect",
      "attributes": {},
      "authorizationSettings": {
        "allowRemoteResourceManagement": false,
        "policyEnforcementMode": "ENFORCING",
        "resources": [],
        "policies": [],
        "scopes": [],
        "decisionStrategy": "UNANIMOUS"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full platform admin"
      },
      {
        "name": "agent",
        "description": "Can invoke registered tools"
      },
      {
        "name": "auditor",
        "description": "Read-only audit and reporting"
      },
      {
        "name": "security_reviewer",
        "description": "Can approve/reject/request-changes on server submissions (not the submitter's own)"
      },
      {
        "name": "readonly",
        "description": "Read-only tool catalogue"
      },
      {
        "name": "grafana-admin",
        "description": "Grafana admin role"
      },
      {
        "name": "grafana-editor",
        "description": "Grafana editor role"
      },
      {
        "name": "grafana-viewer",
        "description": "Grafana viewer role"
      }
    ]
  },
  "users": [
    {
      "username": "alice",
      "email": "alice@lab.local",
      "enabled": true,
      "firstName": "Alice",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "${DEX_ALICE_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "grafana-admin"
      ],
      "emailVerified": true
    },
    {
      "username": "bob",
      "email": "bob@lab.local",
      "enabled": true,
      "firstName": "Bob",
      "lastName": "Agent",
      "credentials": [
        {
          "type": "password",
          "value": "${DEX_BOB_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "agent",
        "grafana-editor"
      ],
      "emailVerified": true
    },
    {
      "username": "carol",
      "email": "carol@lab.local",
      "enabled": true,
      "firstName": "Carol",
      "lastName": "Auditor",
      "credentials": [
        {
          "type": "password",
          "value": "labpassword",
          "temporary": false
        }
      ],
      "realmRoles": [
        "auditor",
        "security_reviewer",
        "grafana-viewer"
      ],
      "emailVerified": true
    },
    {
      "username": "service-account-svc-mcp-agent",
      "email": "svc-mcp-agent@lab.local",
      "emailVerified": true,
      "enabled": true,
      "serviceAccountClientId": "svc-mcp-agent",
      "realmRoles": [
        "agent"
      ]
    }
  ],
  "identityProviders": [],
  "browserSecurityHeaders": {
    "contentTypeOptions": "nosniff",
    "xRobotsTag": "none",
    "xFrameOptions": "SAMEORIGIN",
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';"
  },
  "verifyEmail": true,
  "editUsernameAllowed": false
}
