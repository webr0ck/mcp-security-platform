# MCP Security Platform — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# All secrets must use strong random values in production.

# =============================================================================
# DEPLOYMENT
# =============================================================================
ENVIRONMENT=development
# Options: development | staging | production
# Controls: OPA bundle signing enforcement, TLS strictness, debug logging

LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR

# =============================================================================
# POSTGRESQL
# =============================================================================
DB_HOST=db
DB_PORT=5432
DB_NAME=mcp_security
DB_USER=mcp_app
DB_PASSWORD=your-strong-database-password-here
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Compliance checker uses a separate read-only user
COMPLIANCE_DB_USER=compliance_checker
COMPLIANCE_DB_PASSWORD=your-compliance-checker-db-password-here

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-strong-redis-password-here
REDIS_DB=0
REDIS_RATE_LIMIT_DB=1

# =============================================================================
# PROXY APPLICATION
# =============================================================================
PROXY_HOST=0.0.0.0
PROXY_PORT=8000
PROXY_WORKERS=4
PROXY_SECRET_KEY=your-32-byte-random-secret-key-here

# API key hashing salt (SHA-256 HMAC key)
API_KEY_HMAC_KEY=your-api-key-hmac-signing-key-here

# =============================================================================
# SIGNING KEYS
# =============================================================================
# SBOM document signing (HMAC-SHA-256)
SBOM_SIGNING_KEY=your-sbom-signing-key-min-32-bytes-here

# Audit log event integrity HMAC
AUDIT_LOG_HMAC_KEY=your-audit-log-hmac-key-min-32-bytes-here

# Webhook outbound signature
WEBHOOK_SIGNING_KEY=your-webhook-signing-key-min-32-bytes-here

# OPA policy bundle signing key (required when ENVIRONMENT=production)
POLICY_SIGNING_KEY=your-opa-policy-bundle-signing-key-here
POLICY_SIGNING_KEY_ID=mcp-policy-signing-key-v1

# =============================================================================
# NGINX GATEWAY
# =============================================================================
NGINX_CLIENT_MAX_BODY_SIZE=10m
# Rate limiting defaults (requests per minute, overridden per role in proxy)
NGINX_RATE_LIMIT_ZONE_SIZE=10m
NGINX_RATE_LIMIT_BURST=20

# =============================================================================
# STEP-CA (Internal Certificate Authority)
# =============================================================================
STEP_CA_HOST=step-ca
STEP_CA_PORT=9000
STEP_CA_URL=https://step-ca:9000
STEP_CA_FINGERPRINT=your-step-ca-root-fingerprint-here
STEP_CA_PROVISIONER_NAME=mcp-security-platform
STEP_CA_PROVISIONER_PASSWORD=your-step-ca-provisioner-password-here
# Certificate TTL maximum (must not exceed 24h per INV-010)
STEP_CA_MAX_TLS_DURATION=24h

# =============================================================================
# OPA SIDECAR
# =============================================================================
OPA_HOST=opa
OPA_PORT=8181
OPA_URL=http://opa:8181
OPA_TIMEOUT_SECONDS=2
# Decision log level: off | error | info | debug
OPA_DECISION_LOG_LEVEL=info

# =============================================================================
# OLLAMA (Local LLM for Risk Scoring)
# =============================================================================
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=30
# Risk score threshold above which a tool is flagged as 'high' (0-100)
OLLAMA_HIGH_RISK_THRESHOLD=70
# Risk score threshold above which a tool is flagged as 'critical' (0-100)
OLLAMA_CRITICAL_RISK_THRESHOLD=90

# =============================================================================
# OIDC (Optional — enable for human user authentication)
# =============================================================================
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://your-oidc-provider.example.com/realms/mcp
OIDC_CLIENT_ID=mcp-security-platform
OIDC_CLIENT_SECRET=your-oidc-client-secret-here
OIDC_AUDIENCE=mcp-security-platform
OIDC_ROLE_CLAIM_PATH=roles
# Redirect URI after OIDC callback (must match provider configuration)
OIDC_REDIRECT_URI=https://your-platform-host/api/v1/auth/oidc/callback

# =============================================================================
# MINIO (S3-compatible WORM Storage)
# =============================================================================
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=your-minio-admin-username
MINIO_ROOT_PASSWORD=your-strong-minio-root-password-here
MINIO_AUDIT_BUCKET=mcp-audit-archive
# Object Lock retention in days (minimum 90 for compliance)
MINIO_RETENTION_DAYS=90

# In production, replace MinIO with real S3:
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION=us-east-1
# S3_AUDIT_BUCKET=your-s3-worm-bucket-name

# =============================================================================
# GRAFANA
# =============================================================================
GRAFANA_HOST=grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-strong-grafana-admin-password-here

# =============================================================================
# LOKI
# =============================================================================
LOKI_HOST=loki
LOKI_PORT=3100
LOKI_URL=http://loki:3100

# =============================================================================
# ALERTMANAGER
# =============================================================================
ALERTMANAGER_HOST=alertmanager
ALERTMANAGER_PORT=9093
# ALERT_WEBHOOK_URL: primary webhook for all alertmanager receivers (rendered
# into alertmanager.yml by the alertmanager-config-renderer init container).
# In production set this to your Slack incoming webhook, PagerDuty endpoint, etc.
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/your-slack-webhook-here
# ALERT_WEBHOOK_URL_CRITICAL: high-urgency override (e.g. PagerDuty).
# If unset, defaults to ALERT_WEBHOOK_URL (handled by entrypoint.sh renderer).
ALERT_WEBHOOK_URL_CRITICAL=
# Legacy name (kept for compatibility with compliance-checker):
ALERTMANAGER_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-slack-webhook-here
ALERTMANAGER_EMAIL_TO=security-team@your-org.example.com
ALERTMANAGER_EMAIL_FROM=mcp-alerts@your-org.example.com
ALERTMANAGER_SMTP_HOST=smtp.your-org.example.com:587
# GF_ALERTING_WEBHOOK_URL: contact point for Grafana Unified Alerting rules
# (mcp-alerts.yml). Usually the same as ALERT_WEBHOOK_URL.
GF_ALERTING_WEBHOOK_URL=https://hooks.slack.com/services/your-slack-webhook-here
GF_ALERTING_WEBHOOK_URL_CRITICAL=

# =============================================================================
# JIRA INTEGRATION (Optional)
# =============================================================================
JIRA_ENABLED=false
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_USER_EMAIL=service-account@your-org.example.com
JIRA_PROJECT_KEY=MSEC
JIRA_WEBHOOK_SECRET=your-jira-webhook-shared-secret-here
# Issue type to create for critical-risk tool flags
JIRA_ISSUE_TYPE=Security Task

# =============================================================================
# ARTIFACTORY INTEGRATION (Optional)
# =============================================================================
ARTIFACTORY_ENABLED=false
ARTIFACTORY_BASE_URL=https://your-org.jfrog.io/artifactory
ARTIFACTORY_REPO=mcp-sbom-local
ARTIFACTORY_API_KEY=your-artifactory-api-key-here

# =============================================================================
# COMPLIANCE CHECKER
# =============================================================================
# Cron schedule (default: 02:00 UTC daily)
COMPLIANCE_CRON_SCHEDULE=0 2 * * *
COMPLIANCE_SAMPLE_SIZE=1000
COMPLIANCE_ALERT_WEBHOOK=http://alertmanager:9093/api/v1/alerts

# =============================================================================
# OUTBOUND WEBHOOKS (Optional)
# =============================================================================
WEBHOOK_ENABLED=false
WEBHOOK_TARGET_URL=https://your-webhook-receiver.example.com/mcp-events
# Events: tool.registered, tool.quarantined, anomaly.detected, compliance.report.failed
WEBHOOK_EVENTS=tool.quarantined,anomaly.detected,compliance.report.failed

# =============================================================================
# RATE LIMITING (requests per minute per role)
# =============================================================================
RATE_LIMIT_ADMIN=300
RATE_LIMIT_AGENT=120
RATE_LIMIT_AUDITOR=60
RATE_LIMIT_READONLY=30

# =============================================================================
# CREDENTIAL BROKER (CB-015 — previously undocumented; operators inherited
# config.py defaults incl. a placeholder VAULT_TOKEN)
# =============================================================================
# Vault KMS — VAULT_ADDR MUST be https:// outside ENVIRONMENT=development
# (CB-002, enforced at config load). VAULT_CA_BUNDLE optional (path to CA PEM;
# empty = system trust store).
VAULT_ADDR=https://vault:8200
VAULT_TOKEN=change-me-in-production
VAULT_CA_BUNDLE=
BROKER_MASTER_SECRET_PATH=secret/data/credential-broker
BROKER_MASTER_SECRET_TTL_SECONDS=300

# OAuth enrollment CSRF state signing (CB-003)
OAUTH_STATE_SECRET=change-me-in-production

# M365 / Entra (Approach A OAuth)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=https://localhost/auth/callback/m365
ENTRA_SCOPES=Mail.Read Calendars.Read

# Bitbucket (Approach A OAuth)
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
BITBUCKET_REDIRECT_URI=https://localhost/auth/callback/bitbucket

# Dex (lab OIDC IdP)
DEX_CLIENT_ID=mcp-proxy
DEX_CLIENT_SECRET=change-me-in-production
DEX_REDIRECT_URI=https://localhost/auth/callback/dex

# Grafana / Netbox service-account tokens (Approach B)
GRAFANA_ADMIN_TOKEN=
NETBOX_ADMIN_TOKEN=
