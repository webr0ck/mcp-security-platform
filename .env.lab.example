# Example lab environment file.
# Copy to .env.lab and fill in values before running `make -f Makefile.lab lab-up`.
# .env.lab is gitignored — never commit real credentials.

# ── Lab Services ──────────────────────────────────────────────────────────────
LAB_GRAFANA_ADMIN_PASSWORD=labpassword
LAB_NETBOX_DB_PASSWORD=labpassword
LAB_NETBOX_REDIS_PASSWORD=labpassword
LAB_NETBOX_SECRET_KEY=change-me-at-least-50-chars-for-netbox-secret-key
LAB_NETBOX_ADMIN_PASSWORD=labpassword

# ── Dex Local IdP ─────────────────────────────────────────────────────────────
DEX_CLIENT_SECRET=mcp-proxy-secret
DEX_ALICE_PASSWORD=labpassword
DEX_BOB_PASSWORD=labpassword

# ── Credential Broker (Lab) ───────────────────────────────────────────────────
GRAFANA_BASE_URL=http://lab-grafana:3000
GRAFANA_ADMIN_TOKEN=                    # filled by lab-init after Grafana SA creation
GRAFANA_SERVICE_ACCOUNT_ID=1
NETBOX_BASE_URL=http://lab-netbox:8080
NETBOX_ADMIN_TOKEN=                     # filled by lab-init after NetBox token creation

# ── Dex OIDC Adapter (set in proxy config) ───────────────────────────────────
DEX_ISSUER_URL=http://localhost:5556/dex
DEX_CLIENT_ID=mcp-proxy
DEX_REDIRECT_URI=http://localhost:8000/auth/callback/dex
DEX_SCOPES="openid profile email offline_access"

# ── Entra Test Tenant (optional — for Graph API tests) ───────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# No redirect URI needed — client_credentials flow only

# ── M365 mock mode (PRD-0002 Case 1) ─────────────────────────────────────────
# Case 1: AZURE_MODE=mock uses mock-idp + mock-graph (no real Entra needed)
# Set to 'real' to use actual Azure credentials above
AZURE_MODE=mock
M365_TOKEN_URL=http://lab-mock-idp:8888/oauth/token
M365_GRAPH_BASE=http://lab-mock-graph:8000/v1.0

# ── Vault (lab uses dev mode) ─────────────────────────────────────────────────
VAULT_TOKEN=lab-root-token
# NOTE: the lab remaps Vault to host port 8201 (8200 collides with other local services)
VAULT_ADDR=http://localhost:8201

# ── Copy these from main .env ──────────────────────────────────────────────────
DB_PASSWORD=devpassword
REDIS_PASSWORD=devpassword
PROXY_SECRET_KEY=devpassword
API_KEY_HMAC_KEY=devpassword
SBOM_SIGNING_KEY=devpassword
AUDIT_LOG_HMAC_KEY=devpassword
WEBHOOK_SIGNING_KEY=devpassword
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniopassword
BROKER_MASTER_SECRET_PATH=secret/data/mcp/broker-master
# NOTE: the broker master secret (KEK) is NOT stored in this file. The lab Vault
# now uses PERSISTENT file storage (lab/vault/local.hcl + auto-unseal.sh), so the
# KEK lives only inside Vault's encrypted barrier on the vault-data volume and
# survives restarts. VAULT_TOKEN below doubles as the fixed bootstrap token the
# auto-unseal wrapper mints (valid only against the live, unsealed Vault).
# To intentionally rotate the KEK (orphans existing creds): FORCE_ROTATE_MASTER=true
OAUTH_STATE_SECRET=lab-state-secret-change-me
