# deployments/standard/.env.example
# Tier 2 — Standard (engine + Keycloak + Grafana)
# Run bash scripts/init-standard.sh to auto-generate all passwords.

ENVIRONMENT=production
LOG_LEVEL=INFO

# PostgreSQL (REQUIRED)
DB_HOST=db
DB_PORT=5432
DB_NAME=mcp_security
DB_USER=mcp_app
DB_PASSWORD=

# Redis (REQUIRED)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_RATE_LIMIT_DB=1

# Proxy application (REQUIRED)
PROXY_HOST=0.0.0.0
PROXY_PORT=8000
PROXY_WORKERS=4
PROXY_SECRET_KEY=
API_KEY_HMAC_KEY=
SBOM_SIGNING_KEY=
AUDIT_LOG_HMAC_KEY=
OAUTH_STATE_SECRET=

# Vault (REQUIRED)
VAULT_ADDR=https://vault:8200
VAULT_TOKEN=

# Keycloak — auto-generated by init-standard.sh
KC_ADMIN_PASSWORD=
KC_PROXY_CLIENT_SECRET=
KC_GRAFANA_CLIENT_SECRET=

# OIDC (proxy → Keycloak) — auto-populated after init
OIDC_ENABLED=true
OIDC_ISSUER_URL=http://localhost:8082/realms/mcp
OIDC_INTERNAL_ISSUER_URL=http://keycloak:8080/realms/mcp
OIDC_CLIENT_ID=mcp-proxy
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=mcp-proxy
OIDC_ROLE_CLAIM_PATH=roles
OIDC_REDIRECT_URI=https://localhost/api/v1/auth/oidc/callback

# Admin password — auto-generated by init-standard.sh
# ADMIN_PASSWORD=
