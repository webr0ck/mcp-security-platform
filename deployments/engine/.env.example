# deployments/engine/.env.example
# Tier 1 — Engine only (bring your own IDP)
# 1. Copy to repo root: cp deployments/engine/.env.example .env
# 2. Fill all REQUIRED values
# 3. Run: bash scripts/init-engine.sh
# 4. Start: docker compose -f compose.engine.yml up -d

ENVIRONMENT=production
LOG_LEVEL=INFO

# PostgreSQL (REQUIRED)
DB_HOST=db
DB_PORT=5432
DB_NAME=mcp_security
DB_USER=mcp_app
DB_PASSWORD=

# Redis (REQUIRED)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_RATE_LIMIT_DB=1

# Proxy application (REQUIRED — generate with: openssl rand -hex 32)
PROXY_HOST=0.0.0.0
PROXY_PORT=8000
PROXY_WORKERS=4
PROXY_SECRET_KEY=
API_KEY_HMAC_KEY=
SBOM_SIGNING_KEY=
AUDIT_LOG_HMAC_KEY=
OAUTH_STATE_SECRET=

# Vault (REQUIRED)
VAULT_ADDR=https://vault:8200
VAULT_TOKEN=

# Admin password — auto-generated by init-engine.sh on first run
# ADMIN_PASSWORD=

# IDP / OIDC (optional — connect your identity provider)
OIDC_ENABLED=false
# OIDC_ISSUER_URL=https://your-idp.example.com/realms/mcp
# OIDC_CLIENT_ID=mcp-security-platform
# OIDC_CLIENT_SECRET=
# OIDC_AUDIENCE=mcp-security-platform
# OIDC_ROLE_CLAIM_PATH=roles
# OIDC_REDIRECT_URI=https://your-host/api/v1/auth/oidc/callback
