{
  "title": "MCP — Security",
  "uid": "mcp-security",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["mcp", "security"],
  "timezone": "utc",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "loki",
        "label": "Datasource",
        "hide": 0,
        "query": "loki",
        "current": { "text": "Loki", "value": "Loki" },
        "options": [],
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Allowed Invocations",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"mcp-proxy\"} | json | outcome=\"allow\" [$__interval]))",
          "legendFormat": "Allowed",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Denied Invocations",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"mcp-proxy\"} | json | outcome=\"deny\" [$__interval]))",
          "legendFormat": "Denied",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Auth Failures",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"mcp-proxy\"} |= \"401\" [$__interval]))",
          "legendFormat": "Auth Failures",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Credential Events",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"mcp-proxy\"} |= \"CREDENTIAL_\" [$__interval]))",
          "legendFormat": "Credential Events",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "cyan" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "cyan", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Anomaly Detections",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"mcp-proxy\"} |= \"anomaly_threshold_exceeded\" [$__interval]))",
          "legendFormat": "Anomalies",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "yellow", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "OPA Evaluations (allow vs deny)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(rate({job=\"mcp-proxy\"} | json | outcome=\"allow\" [2m]))",
          "legendFormat": "allow",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(rate({job=\"mcp-proxy\"} | json | outcome=\"deny\" [2m]))",
          "legendFormat": "deny",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "spanNulls": false,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "allow" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "deny" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Credential Lifecycle Events",
      "type": "logs",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"mcp-proxy\"} |= \"CREDENTIAL_\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "prettifyLogMessage": false
      }
    },
    {
      "id": 7,
      "title": "Recent Deny Events",
      "type": "logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"mcp-proxy\"} | json | outcome=\"deny\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "showLabels": true,
        "showTime": true,
        "prettifyLogMessage": false
      }
    }
  ]
}
