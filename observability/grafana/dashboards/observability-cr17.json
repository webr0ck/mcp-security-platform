{
  "title": "MCP — Observability (CR-17 / WP-D1)",
  "uid": "mcp-observability-cr17",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["mcp", "cr-17", "prometheus"],
  "timezone": "utc",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "15s",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "OPA reachable",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mcp_opa_up", "legendFormat": "opa_up", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 2,
      "title": "Vault reachable",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mcp_vault_up", "legendFormat": "vault_up", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 3,
      "title": "Quarantine backlog",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mcp_quarantine_backlog", "legendFormat": "quarantined", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 4,
      "title": "Stale scans (SCAN_FRESHNESS_ENFORCED)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mcp_stale_scan_count", "legendFormat": "stale", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 5,
      "title": "Scan dead-letter jobs",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mcp_scan_queue_depth{status=\"dead_letter\"}", "legendFormat": "dead_letter", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 6,
      "title": "Authz deny rate (10m)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(mcp_authz_decisions_total{decision=\"deny\"}[10m])) / sum(rate(mcp_authz_decisions_total[10m]))",
          "legendFormat": "deny_rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.1 }, { "color": "red", "value": 0.3 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 7,
      "title": "Scan queue depth by status",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mcp_scan_queue_depth", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "lineInterpolation": "linear", "spanNulls": false, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Authorization decisions (allow/deny)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(mcp_authz_decisions_total[1m])) by (decision)", "legendFormat": "{{decision}}", "refId": "A" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "lineInterpolation": "linear", "spanNulls": false, "showPoints": "never" },
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Credential broker failures by error type",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(mcp_credential_broker_failures_total[5m])) by (error_type)", "legendFormat": "{{error_type}}", "refId": "A" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "lineInterpolation": "linear", "spanNulls": false, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Audit emission failures (INV-001)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(mcp_audit_emit_failures_total[5m])", "legendFormat": "audit_emit_failures", "refId": "A" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "bars", "lineInterpolation": "linear", "spanNulls": false, "showPoints": "never" },
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "Scanner-worker job lifecycle",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(mcp_scanner_worker_jobs_claimed_total[5m])", "legendFormat": "claimed", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(mcp_scanner_worker_jobs_completed_total[5m])", "legendFormat": "completed", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(mcp_scanner_worker_jobs_requeued_total[5m])", "legendFormat": "requeued", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(mcp_scanner_worker_jobs_dead_letter_total[5m])", "legendFormat": "dead_letter", "refId": "D" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "lineInterpolation": "linear", "spanNulls": false, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "Scanner-worker job duration (p50/p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, rate(mcp_scanner_worker_job_duration_seconds_bucket[5m]))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, rate(mcp_scanner_worker_job_duration_seconds_bucket[5m]))", "legendFormat": "p95", "refId": "B" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "lineInterpolation": "linear", "spanNulls": false, "showPoints": "never" },
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      }
    }
  ]
}
