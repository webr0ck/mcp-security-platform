# Lab targets for Podman-based full-stack testing
# Usage: make -f Makefile.lab <target>
# Prerequisites: podman, podman-compose, python3, curl, jq

LAB_COMPOSE = podman-compose --env-file .env.lab \
  -f docker-compose.yml \
  -f docker-compose.dev.yml \
  -f podman-compose.lab.yml \
  -f compose.wazuh.yml

.PHONY: lab-setup lab-up lab-down lab-reset lab-rebuild lab-recreate lab-init lab-test lab-smoke \
        lab-logs lab-dex-logs lab-ps lab-entra-check lab-vault-init \
        lab-proxy-shell lab-netbox-shell smoke-four lab-acceptance lab-probe wazuh-up wazuh-dashboard-up incidents help

## lab-setup       Zero-to-usable: start stack, migrate DB, provision tokens, seed, smoke test
lab-setup:
	bash lab/scripts/lab-setup.sh

## lab-setup-reset  Full reset then zero-to-usable setup (destroys volumes)
lab-setup-reset:
	bash lab/scripts/lab-setup.sh --reset

## lab-up          Bring up the full lab stack (build + seed)
lab-up:
	$(LAB_COMPOSE) up -d --build
	sleep 10
	$(MAKE) -f Makefile.lab lab-init

## lab-down         Tear down the lab stack (preserves volumes)
lab-down:
	$(LAB_COMPOSE) down

## lab-reset        Tear down including volumes, then bring back up
lab-reset:
	$(LAB_COMPOSE) down -v
	$(MAKE) -f Makefile.lab lab-up

## lab-rebuild      Rebuild and restart only changed services, then re-seed
lab-rebuild:
	$(LAB_COMPOSE) build proxy lab-mcp-grafana mcp-netbox lab-mcp-m365 lab-seeder
	$(LAB_COMPOSE) up -d --no-deps proxy lab-mcp-grafana mcp-netbox lab-mcp-m365
	$(LAB_COMPOSE) run --rm lab-seeder

## lab-recreate     Safely recreate ONE service (image/config bump): make -f Makefile.lab lab-recreate SERVICE=lab-keycloak [PULL=1]
lab-recreate:
	@test -n "$(SERVICE)" || (echo "Usage: make -f Makefile.lab lab-recreate SERVICE=<compose-service-name> [PULL=1]" && exit 1)
	bash lab/scripts/lab-recreate.sh $(SERVICE) $(if $(PULL),--pull,)

## lab-init         Initialise Vault, replay missing migrations, then run the seeder container
lab-init:
	bash lab/scripts/vault-init.sh
	@echo "Replaying migrations (idempotent — piped from host, errors visible)..."
	@failed=0; \
	for f in $$(ls infra/db/migrations/V*.sql | sort); do \
	  fname=$$(basename "$$f"); \
	  out=$$(podman exec -i mcp-db psql -U mcp_app mcp_security 2>&1 < "$$f"); \
	  rc=$$?; \
	  if [ $$rc -ne 0 ]; then \
	    echo "  FAIL $$fname: $$(echo "$$out" | grep -i error | head -1)"; \
	    failed=$$((failed+1)); \
	  fi; \
	done; \
	if [ $$failed -gt 0 ]; then \
	  echo "  $$failed migration(s) failed — check output above"; \
	else \
	  echo "  All migrations OK"; \
	fi
	$(LAB_COMPOSE) run --rm lab-seeder

## lab-test         Run integration / e2e tests (excludes unit-only tests)
lab-test:
	cd proxy && env $$(grep -v '^#' ../.env.lab | xargs) python3 -m pytest tests/ -m "not unit" --tb=short -v

## lab-smoke        Run the smoke-test script against live endpoints
lab-smoke:
	bash lab/scripts/lab-smoke.sh

## lab-probe        CR-17 / WP-D1 synthetic probe: login -> low-risk invoke -> audit check
lab-probe:
	python3 lab/scripts/synthetic_probe.py

## smoke-four       PRD-0002 P0 acceptance test — verify 3/4 auth cases registered
smoke-four:
	bash lab/scripts/smoke_four_cases.sh

## lab-acceptance   Full AT0-AT3 acceptance run against the live lab (brings lab up if needed)
lab-acceptance:
	bash lab/scripts/run_full_acceptance.sh

## wazuh-up           Start full lab stack + Wazuh SIEM + Wazuh MCP server (no dashboard)
wazuh-up:
	$(LAB_COMPOSE) up -d --build
	@echo "Wazuh API:  https://localhost:55000  (admin / \$$WAZUH_API_PASSWORD from .env.lab)"
	@echo "Wazuh MCP:  proxied via http://localhost:8000/mcp  (tool: wazuh-siem)"
	@echo "Dashboard:  run 'make wazuh-dashboard-up' for the full Wazuh UI (~4GB RAM)"

## wazuh-dashboard-up  Start full Wazuh stack including indexer + dashboard UI (~4GB RAM)
wazuh-dashboard-up:
	@echo "Generating Wazuh TLS certificates (if missing)..."
	@if [ ! -f lab/wazuh/certs/root-ca.pem ]; then \
	  podman run --rm \
	    -v "$(PWD)/lab/wazuh/certs-config.yml:/config/certs.yml:ro,z" \
	    -v "$(PWD)/lab/wazuh/certs:/certificates:z" \
	    wazuh/wazuh-certs-generator:0.0.2 \
	    /entrypoint.sh 2>&1 | tail -5; \
	  echo "  Certs generated in lab/wazuh/certs/"; \
	else \
	  echo "  Certs already present (lab/wazuh/certs/root-ca.pem exists)."; \
	fi
	@echo "Starting Wazuh with indexer + dashboard (requires ~4GB RAM total)..."
	WAZUH_INDEXER_URL=https://wazuh-indexer:9200 $(LAB_COMPOSE) --profile dashboard up -d --build || true
	@echo "Starting stragglers that may have missed dependency window..."
	@sleep 3
	WAZUH_INDEXER_URL=https://wazuh-indexer:9200 $(LAB_COMPOSE) --profile dashboard up -d --no-deps lab-wazuh-indexer lab-wazuh-dashboard lab-wazuh-manager 2>/dev/null || true
	@echo ""
	@echo "Wazuh Dashboard: http://192.168.0.10:5601"
	@echo "  Login: admin / \$$WAZUH_INDEXER_PASSWORD (default: labpassword)"
	@echo "Wazuh API:       https://192.168.0.10:55000  (wazuh / \$$WAZUH_API_PASSWORD)"
	@echo ""
	@echo "NOTE: Dashboard takes 2-3 min to fully initialize (indexer start_period: 90s)."
	@echo "      To persist the indexer password: add WAZUH_INDEXER_PASSWORD=<pass> to .env.lab"

## wazuh-filebeat-up  Also start Filebeat log shipper (set PODMAN_SOCK in .env.lab first)
wazuh-filebeat-up:
	$(LAB_COMPOSE) --profile filebeat up -d --build
	@echo "Filebeat started — shipping container logs to wazuh-manager:5044"

## incidents        List available incident scenarios and run them
incidents:
	@echo "Available incident scenarios (run individually):"
	@echo "  bash lab/incidents/01-stolen-sa-token/trigger.sh"
	@echo "  bash lab/incidents/02-overprivileged-user/trigger.sh"
	@echo "  bash lab/incidents/03-token-exchange-abuse/trigger.sh"
	@echo "  bash lab/incidents/04-m365-mail-exfil/trigger.sh"
	@echo ""
	@echo "Wazuh rules: deployments/poc/wazuh/rules/mcp-audit-rules.xml (rules 100600-100603)"
	@echo "Grafana:     http://localhost:3000 → Four-Auth Trace (PRD-0002)"

## lab-logs         Follow logs for core lab services
lab-logs:
	$(LAB_COMPOSE) logs -f proxy lab-dex lab-grafana lab-netbox

## lab-dex-logs     Follow logs for Dex IdP only
lab-dex-logs:
	$(LAB_COMPOSE) logs -f lab-dex

## lab-ps           Show running container status for the lab stack
lab-ps:
	$(LAB_COMPOSE) ps

## lab-entra-check  Verify Entra / Graph API connectivity (requires ENTRA_* vars)
lab-entra-check:
	bash lab/scripts/entra-check.sh

## lab-vault-init   Initialise and unseal Vault, write lab secrets
lab-vault-init:
	bash lab/scripts/vault-init.sh

## lab-proxy-shell  Open a bash shell inside the proxy container
lab-proxy-shell:
	$(LAB_COMPOSE) exec proxy bash

## lab-netbox-shell Open a sh shell inside the NetBox container
lab-netbox-shell:
	$(LAB_COMPOSE) exec lab-netbox /bin/sh

## lab-backfill-sboms  Generate signed SBOMs for seeded tools that lack one
lab-backfill-sboms:
	$(LAB_COMPOSE) exec proxy python /scripts/backfill_sboms.py

## provision-demo     Auto-provision the two demo MCP flows end-to-end (flow A upload + flow B scaffold)
provision-demo:
	python3 scripts/provision_mcp.py --name demo-uploaded --source $(CURDIR)/sandbox/uploaded-demo-mcp
	python3 scripts/provision_mcp.py --name demo-selfservice --scaffold-mode none

## provision           Auto-provision one MCP: make -f Makefile.lab provision ARGS="--name x --source ./dir"
provision:
	python3 scripts/provision_mcp.py $(ARGS)

## help             Show this help message
help:
	@grep -E '^## ' Makefile.lab | sed 's/^## //' | awk 'BEGIN {FS="  +"} {printf "  \033[36m%-22s\033[0m %s\n", $$1, $$2}'
